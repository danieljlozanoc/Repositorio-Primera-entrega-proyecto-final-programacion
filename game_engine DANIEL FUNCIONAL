def get_player_pieces(player_id):
    """
    Return all pieces of player and their positions.
    """
    global board_state

    for player in board_state["players"]:
        if player["id"] == player_id:
            return {
                "message_type": "unicast",
                "pieces": player["pieces"]
            }

    return {
        "message_type": "unicast",
        "error": "Jugador no encontrado"
    }


def can_piece_move(player_id, piece_id, dice_value):
    """
    Validate if selected piece can move.
    Checks: jail, movement limit, blockades.
    """
    global board_state

    for player in board_state["players"]:
        if player["id"] == player_id:
            pos_actual = player["pieces"][piece_id]

            if pos_actual == -1:
                return False

            if pos_actual + dice_value > FINAL_PATH:
                return False

            return True

    return False


def move_piece(player_id, piece_id, cells_to_move):
    """
    Move a piece by the given number of cells.
    Validates turn, dice usage, movement legality, captures, and win condition.
    """
    global board_state

    # 1. Validate turn
    if not is_player_turn(player_id):
        return {"message_type": "unicast", "error": "No es tu turno."}

    # 2. Validate dice were rolled
    moves = board_state.get("dice_moves")
    if moves is None:
        return {"message_type": "unicast", "error": "Debes lanzar los dados primero."}

    idx = int(piece_id)
    cells_to_move = int(cells_to_move)

    # 3. Validate piece index
    if idx < 0 or idx >= 4:
        return {"message_type": "unicast", "error": "Ficha inválida."}

    # 4. Find player
    p_actual = None
    for p in board_state["players"]:
        if p["id"] == player_id:
            p_actual = p

    if p_actual is None:
        return {"message_type": "unicast", "error": "Jugador no encontrado."}

    # 5. Validate move against available dice values
    move_type = None

    if cells_to_move == moves["d1"] and not moves["used_d1"]:
        move_type = "d1"
    elif cells_to_move == moves["d2"] and not moves["used_d2"]:
        move_type = "d2"
    elif cells_to_move == moves["sum"] and not moves["used_sum"]:
        move_type = "sum"

    if move_type is None:
        return {
            "message_type": "unicast",
            "error": f"Movimiento no válido. Opciones: {moves['d1']}, {moves['d2']} o {moves['sum']}"
        }

    # 6. Validate if piece can actually move
    if not can_piece_move(player_id, idx, cells_to_move):
        pos_actual = p_actual["pieces"][idx]
        if pos_actual == -1:
            return {
                "message_type": "unicast",
                "error": "Esa ficha está en la cárcel. Necesitas un par para sacarla. Intenta mover otra ficha."
            }
        return {
            "message_type": "unicast",
            "error": "Esta ficha no puede moverse con ese valor (se pasaría de la meta). Intenta con otra ficha."
        }

    # 7. Consume dice (V1 fix: using d1/d2 individually does NOT consume the sum)
    if move_type == "d1":
        moves["used_d1"] = True
    elif move_type == "d2":
        moves["used_d2"] = True
    elif move_type == "sum":
        moves["used_sum"] = True
        moves["used_d1"] = True
        moves["used_d2"] = True

    # 8. Move the piece
    p_actual["pieces"][idx] += cells_to_move
    nueva_pos = p_actual["pieces"][idx]

    # 9. Calculate real board position
    mi_pos_real = get_real_position(player_id, nueva_pos)

    # 10. Check capture (only on circular track, non-safe squares)
    if nueva_pos < CIRCULAR_TRACK and mi_pos_real is not None and not is_safe_square(mi_pos_real):
        rival_id, rival_piece_idx = check_capture(player_id, mi_pos_real)
        if rival_id is not None:
            send_piece_home(rival_id, rival_piece_idx)

    # 11. Check win condition
    if has_player_won(player_id):
        board_state["game_state"] = GAME_STATES[3]
        return {
            "message_type": "broadcast",
            "winner": player_id,
            "board_state": board_state
        }

    # 12. Turn control (V1 fix: extra_turn resets dice but keeps the same player)
    turn_finished = moves["used_sum"] or (moves["used_d1"] and moves["used_d2"])

    if turn_finished:
        if board_state.get("extra_turn"):
            board_state["dice_moves"] = None
            board_state["extra_turn"] = False
        else:
            next_turn()

    return {
        "message_type": "broadcast",
        "players": board_state["players"],
        "current_player": board_state["current_player"],
        "dice_moves": moves
    }


