def get_board():
    """
    Return full board representation.
    """
    global board_state

    board_view = []
    for player in board_state["players"]:
        board_view.append({
            "player": player["name"],
            "color": player["color"],
            "pieces": player["pieces"]
        })

    return {
        "message_type": "unicast",
        "board": board_view,
        "current_player": board_state["current_player"]
    }


def is_safe_square(position):
    """
    Return True if the square is a safe zone.
    """
    return position in SAFE_SQUARE


def detect_blockade(position):
    """
    Return True if position contains a blockade.
    """
    pass


def get_real_position(player_id, pos_rel):
    """
    Convert a player's relative position to absolute board position.
    Returns None if piece is in jail or at goal.
    """
    if pos_rel < 0 or pos_rel >= CIRCULAR_TRACK:
        return None

    if player_id == board_state["players"][0]["id"]:
        return pos_rel
    elif player_id == board_state["players"][1]["id"]:
        return (pos_rel + 34) % CIRCULAR_TRACK

    return None


# =================================================
# CAPTURE & RULES
# =================================================

def check_capture(player_id, position):
    """
    Determine if a capture occurs at the given absolute position.
    """
    for opponent in board_state["players"]:
        if opponent["id"] != player_id:
            for i in range(len(opponent["pieces"])):
                pos_rel = opponent["pieces"][i]

                if pos_rel < 0 or pos_rel >= CIRCULAR_TRACK:
                    continue

                pos_real = get_real_position(opponent["id"], pos_rel)

                if pos_real == position:
                    return opponent["id"], i

    return None, None


def send_piece_home(player_id, piece_id):
    """
    Return a captured piece to jail.
    """
    global board_state

    for player in board_state["players"]:
        if player["id"] == player_id:
            player["pieces"][piece_id] = -1
            return True

    return False


def can_exit_jail(player_id, is_double):
    """
    Validate if player can leave jail (all pieces in jail requires a double).
    """
    global board_state

    for player in board_state["players"]:
        if player["id"] == player_id:
            all_in_jail = all(piece == -1 for piece in player["pieces"])
            if all_in_jail:
                return is_double
            return True

    return False


# =================================================
# WIN CONDITION
# =================================================

def has_player_won(player_id):
    """
    Return True if all pieces reached home (position 70).
    """
    for player in board_state["players"]:
        if player["id"] == player_id:
            return player["pieces"] == [FINAL_PATH, FINAL_PATH, FINAL_PATH, FINAL_PATH]
    return False


def check_game_finished():
    """
    Check if any player has won and update game state accordingly.
    """
    global board_state

    for player in board_state["players"]:
        if has_player_won(player["id"]):
            board_state["game_state"] = GAME_STATES[3]
            return {
                "message_type": "broadcast",
                "winner": player["id"],
                "game_state": board_state["game_state"]
            }

    return {
        "message_type": "unicast",
        "game_state": board_state["game_state"]
    }


