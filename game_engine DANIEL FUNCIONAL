# DICE LOGIC
# =================================================

def set_dice(d1, d2):
    """
    Force specific dice values for testing purposes.
    Returns the forced tuple (d1, d2).
    """
    return int(d1), int(d2)


def roll_dice(player_id, force_values=None):
    """
    Roll dice for a player.
    Handles both the turn-order definition phase and the regular game phase.
    Use force_values=(d1, d2) or call set_dice(d1, d2) to force values for testing.
    """
    global board_state
    global first_turn

    # Validate player exists
    player_ids = [p["id"] for p in board_state["players"]]
    if player_id not in player_ids:
        return {
            "message_type": "unicast",
            "error": "Jugador no válido."
        }

    # =============================
    # PHASE 1: DEFINE TURN ORDER
    # =============================
    if board_state["game_state"] == GAME_STATES[1]:

        if not is_player_turn(player_id):
            return {
                "message_type": "unicast",
                "error": "No es tu turno para lanzar."
            }

        dice0, dice1 = random_dices() if force_values is None else force_values
        first_turn["rolls"] += 1

        # El primer jugador simplemente guarda su valor; el segundo compara contra él
        if first_turn["rolls"] == 1:
            first_turn["draw"].add(player_id)
            first_turn["turn"] = player_id
        else:
            valor_anterior = board_state["dices_value"][0]
            if dice0 > valor_anterior:
                first_turn["draw"] = {player_id}
                first_turn["turn"] = player_id
            elif dice0 == valor_anterior:
                first_turn["draw"].add(player_id)
            # Si dice0 < valor_anterior, el primero sigue ganando, no cambia nada

        board_state["dices_value"] = (dice0, dice1)

        # Swap to let the other player roll
        if board_state["players"][0]["id"] == player_id:
            board_state["current_player"] = board_state["players"][1]["id"]
        else:
            board_state["current_player"] = board_state["players"][0]["id"]

        # Both players have rolled
        if first_turn["rolls"] == 2:
            if len(first_turn["draw"]) == 1:
                board_state["current_player"] = first_turn["turn"]
                board_state["game_state"] = GAME_STATES[2]
            else:
                # Tie → restart
                first_turn["rolls"] = 0
                first_turn["turn"] = None
                first_turn["draw"] = set()
                board_state["current_player"] = board_state["players"][0]["id"]

        return {
            "message_type": "broadcast",
            "dice": board_state["dices_value"],
            "current_player": board_state["current_player"],
            "game_state": board_state["game_state"]
        }

    # =============================
    # PHASE 2: NORMAL GAME
    # =============================
    if board_state["game_state"] == GAME_STATES[2]:

        if not is_player_turn(player_id):
            return {
                "message_type": "unicast",
                "error": "No es tu turno."
            }

        # Validar que no haya movimientos pendientes antes de lanzar de nuevo
        moves = board_state.get("dice_moves")
        if moves is not None:
            dados_pendientes = (not moves["used_d1"] or not moves["used_d2"]) and not moves["used_sum"]
            if dados_pendientes:
                return {
                    "message_type": "unicast",
                    "error": "Debes mover tus fichas pendientes antes de volver a lanzar."
                }

        dice0, dice1 = random_dices() if force_values is None else force_values

        player = None
        for p in board_state["players"]:
            if p["id"] == player_id:
                player = p

        if player is None:
            return {
                "message_type": "unicast",
                "error": "Jugador no encontrado."
            }

        board_state["dices_value"] = (dice0, dice1)
        board_state["dice_moves"] = {
            "d1": dice0,
            "d2": dice1,
            "sum": dice0 + dice1,
            "used_d1": False,
            "used_d2": False,
            "used_sum": False
        }
        board_state["last_dice"] = dice0 + dice1

        is_double = (dice0 == dice1)

        # Verificar si TODAS las fichas están en cárcel
        all_in_jail = all(
            piece == -1
            for p in board_state["players"] if p["id"] == player_id
            for piece in p["pieces"]
        )

        if not can_exit_jail(player_id, is_double):
            # Todas en cárcel y no sacó par → contar intento
            intentos = board_state["jail_attempts"].get(player_id, 0) + 1
            board_state["jail_attempts"][player_id] = intentos
            board_state["dice_moves"] = None

            if intentos >= 3:
                # Agotó los 3 intentos → pierde turno y resetea contador
                board_state["jail_attempts"][player_id] = 0
                next_turn()
                return {
                    "message_type": "broadcast",
                    "dice": (dice0, dice1),
                    "is_double": is_double,
                    "current_player": board_state["current_player"],
                    "warning": "Agotaste tus 3 intentos para salir de la cárcel. Turno perdido."
                }
            else:
                # Aún tiene intentos → NO pierde turno, puede volver a lanzar
                return {
                    "message_type": "unicast",
                    "dice": (dice0, dice1),
                    "is_double": is_double,
                    "current_player": board_state["current_player"],
                    "warning": f"No sacaste par. Intento {intentos}/3. Vuelve a lanzar."
                }

        if is_double:
            fichas_liberadas = False
            for p in board_state["players"]:
                if p["id"] == player_id:
                    for i in range(len(p["pieces"])):
                        if p["pieces"][i] == -1:
                            p["pieces"][i] = 0
                            fichas_liberadas = True
            board_state["extra_turn"] = True
            # Resetear intentos de cárcel al salir exitosamente
            board_state["jail_attempts"][player_id] = 0

            if fichas_liberadas:
                # Si salió de la cárcel, solo puede usar UN dado para mover
                # Marcamos d2 como usado para dejar solo d1 disponible
                board_state["dice_moves"]["used_d2"] = True
                board_state["dice_moves"]["used_sum"] = True
            else:
                # No había fichas en cárcel, puede usar ambos dados normalmente
                pass
        else:
            board_state["extra_turn"] = False
        return {
            "message_type": "broadcast",
            "dice": (dice0, dice1),
            "is_double": is_double,
            "pieces": player["pieces"],
            "current_player": board_state["current_player"]
        }

    return {"message_type": "unicast", "error": "El juego no está en curso."}


def get_last_dice():
    """
    Return last rolled dice value.
    """
    global board_state

    return {
        "message_type": "unicast",
        "dice": board_state["dices_value"]
    }


