def can_piece_move(player_id, piece_id, dice_value):
    """
    Validate if selected piece can move.

    Must check:
    - Piece in jail
    - Dice allows exit
    - Movement does not exceed home
    - Blockades
    """
    global board_state

    for player in board_state["players"]:
        if player["id"] == player_id:

            pos_actual = player["pieces"][piece_id]

            # Ficha en cárcel → no se mueve
            if pos_actual == -1:
                return False

            # No puede pasarse de la meta
            if pos_actual + dice_value > FINAL_PATH:
                return False
            #Revisar bloqueos en el camino
            for numero in range(1, dice_value + 1):

                casilla = pos_actual + numero

                if detect_blockade(casilla) == 2:
                    return False
            
            return True

    return False







def detect_blockade(position):
     
     global board_state

     for player in board_state["players"]:
        count = 0
        for piece in player["pieces"]:
            if piece == -1:
                continue
            if piece >= CIRCULAR_TRACK:
                continue
            if piece == position:
                count += 1
        if count == 2:
            return 2

     return 0
