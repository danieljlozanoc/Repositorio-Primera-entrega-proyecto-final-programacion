# test_client.py

from client_transport import GameClient


# Function handling responses from server
def handle_response(response):
    print("Response from server:")
    print(response)


def main():

    client = GameClient("ws://127.0.0.1:8765", handle_response)
    client.connect()

    player = input("Enter player name: ")
    client.send_action("join", player_name=player)

    while True:
        print("\nComandos disponibles:")
        print("  Info:      get_players / get_my_id / current_player / get_state / get_board / get_status")
        print("  Dados:     roll_dice / set_dice <d1> <d2> / get_last_dice")
        print("  Fichas:    move_piece / get_pieces / get_real_position <pos>")
        print("  Turno:     next_turn")
        print("  Salir:     exit")

        command = input("\nComando: ").split()
        if not command:
            continue

        args = command[1:]
        command = command[0]

        if command == "exit":
            break

        # -----------------------------
        # INFO
        # -----------------------------
        elif command == "get_players":
            client.send_action("get_players")

        elif command == "get_my_id":
            client.send_action("get_my_id")

        elif command == "current_player":
            client.send_action("current_player")

        elif command == "get_state":
            client.send_action("get_state")

        elif command == "get_board":
            client.send_action("get_board")

        elif command == "get_status":
            client.send_action("get_status")

        # -----------------------------
        # DADOS
        # -----------------------------
        elif command == "roll_dice":
            client.send_action("roll_dice")

        elif command == "set_dice":
            if len(args) < 2:
                print("Uso: set_dice <d1> <d2>  (ej: set_dice 6 6)")
            else:
                dices_values = (int(args[0]), int(args[1]))
                client.send_action("set_dices", dices_value=dices_values)

        elif command == "get_last_dice":
            client.send_action("get_last_dice")

        # -----------------------------
        # FICHAS
        # -----------------------------
        elif command == "move_piece":
            piece = input("ID de ficha (0-3): ")
            cells = int(input("Casillas a mover: "))
            client.send_action("move_piece", piece_id=piece, cells_to_move=cells)

        elif command == "get_pieces":
            client.send_action("get_pieces")

        elif command == "get_real_position":
            if len(args) < 1:
                print("Uso: get_real_position <pos_relativa>  (ej: get_real_position 11)")
            else:
                client.send_action("get_real_position", pos_rel=int(args[0]))

        # -----------------------------
        # TURNO
        # -----------------------------
        elif command == "next_turn":
            client.send_action("next_turn")

        else:
            print("Comando desconocido.")

    client.close()


if __name__ == "__main__":
    main()
